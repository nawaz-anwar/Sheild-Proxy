# Shared platform configuration (single source of truth)
PROXY_HTTP_ADDR=:8080
PROXY_METRICS_ADDR=:9090
CONFIG_FILE=/workspace/config/platform.yaml

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=shield_proxy
POSTGRES_USER=shield
POSTGRES_PASSWORD=shield
DATABASE_DSN=postgres://shield:shield@postgres:5432/shield_proxy?sslmode=disable

REDIS_HOST=redis
REDIS_PORT=6379
REDIS_PASSWORD=

JWT_ISSUER=shield-proxy
JWT_AUDIENCE=shield-dashboard
JWT_SECRET=local-dev-jwt-secret
ORIGIN_SECRET=local-dev-origin-signing-secret

RATE_LIMIT_RPS=50
RATE_LIMIT_BURST=100

API_PORT=3000
NUXT_PORT=3001
